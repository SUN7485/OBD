# Fleet OBD - Environment Configuration Template
# Copy this file to .env and fill in your values for local development

# Database
POSTGRES_USER=fleet_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=fleet_obd
DATABASE_URL=postgresql+asyncpg://fleet_user:CHANGE_ME@localhost:5432/fleet_obd

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET=CHANGE_ME_GENERATE_WITH: openssl rand -hex 32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI (Local LLM - Optional)
LM_STUDIO_URL=http://localhost:1234/v1

# MQTT (Local broker - Optional)
MQTT_URL=ws://localhost:8083/mqtt
MQTT_USERNAME=
MQTT_PASSWORD=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Environment
ENVIRONMENT=dev

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Optional: Docker internal URLs (uncomment when using Docker)
# DATABASE_URL=postgresql+asyncpg://fleet_user:CHANGE_ME@postgres:5432/fleet_obd
# REDIS_URL=redis://redis:6379/0
# MQTT_URL=mqtt://mqtt:1883