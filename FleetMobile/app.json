{
  "expo": {
    "name": "FleetMobile",
    "slug": "obd",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fleet.obd"
    },
    "android": {
      "permissions": [
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "ACCESS_FINE_LOCATION"
      ],
      "package": "com.fleet.obd"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-status-bar",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "cmake": {
              "version": "3.22.1"
            },
            "ndk": {
              "version": "25.1.8937393"
            }
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "67a6c0f3-155d-40c0-9000-baa03e0eb00c"
      }
    },
    "owner": "sun74"
  }
}
